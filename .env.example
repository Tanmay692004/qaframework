# Environment Configuration for QA Framework
# Copy this file to .env and customize for your environment

# Application Environment (dev, staging, production)
APP_ENV=dev

# Base URL for the test application
BASE_URL=https://www.saucedemo.com

# Browser Configuration
DEFAULT_BROWSER=chrome

# Implicit wait time (in seconds)
DEFAULT_WAIT_SECONDS=10

# Window size for browser
DEFAULT_WINDOW_SIZE=1920,1080

# Headless mode (true/false) - true for CI, false for local debugging
HEADLESS=true

# Parallel execution workers
PARALLEL_WORKERS=4

# Screenshot settings
SCREENSHOT_ON_FAILURE=true

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Report directory
REPORTS_DIR=reports

# Screenshots directory
SCREENSHOTS_DIR=screenshots

# Environment-specific URLs (optional)
# DEV_URL=http://localhost:3000
# STAGING_URL=https://staging.saucedemo.com
# PRODUCTION_URL=https://www.saucedemo.com
